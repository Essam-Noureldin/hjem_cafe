# ----------------------------------------------------------------------------
# .env.example — Environment variable reference for Hjem Kensington
# ----------------------------------------------------------------------------
# WHAT: Documents every env var the app reads. Committed to git as a template.
# WHY:  So future-you / a future developer / the client can see the full env
#       surface without having to grep through source code.
# HOW TO USE: Copy this file to `.env.local` and fill in real values.
#             `.env.local` is gitignored — never commit secrets.
#
# Naming rule:
#   - NEXT_PUBLIC_* vars are exposed to the browser (safe to be public).
#   - All other vars are server-only and never leave the server.
#   - NEVER prefix a secret like an API key with NEXT_PUBLIC_ — it leaks.
# ----------------------------------------------------------------------------


# ----- Public site config (safe to expose) -----------------------------------

# Full URL of the deployed site, no trailing slash.
# Used by: sitemap generation, Open Graph meta tags, canonical URLs.
# Dev: http://localhost:3000
# Prod: https://hjem-kensington.vercel.app
NEXT_PUBLIC_SITE_URL=

# Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX).
# Leave empty for the demo — GA only loads when this is set AND the user
# accepts cookies. Wire a real GA4 ID once the client signs.
NEXT_PUBLIC_GA_ID=

# Sentry DSN (Data Source Name) — error monitoring URL.
# Leave empty for the demo. /lib/env.ts treats this as optional and will
# silently no-op error reporting when unset.
NEXT_PUBLIC_SENTRY_DSN=


# ----- Contact form (server-only) --------------------------------------------

# Inbox that receives form submissions from the website.
# For the demo build this is Essam's address. Once the client signs, swap
# to the client's address before deploying their version.
CONTACT_FORM_TO_EMAIL=esam.noureldin@gmail.com

# The "From" address shown on outbound emails. MUST be a domain verified in
# the Resend dashboard, otherwise Resend rejects the send.
# DEMO STUB: this is intentionally left empty. The contact form server
# action will skip Resend and log the submission to the server console
# until a real verified sender domain is configured.
CONTACT_FORM_FROM_EMAIL=

# Resend API key (private — never NEXT_PUBLIC_).
# DEMO STUB: leave empty. With both this AND CONTACT_FORM_FROM_EMAIL empty,
# the server action treats Resend as a no-op. As soon as both are set, real
# email delivery activates — no code change needed.
RESEND_API_KEY=


# ----- Rate limiting (server-only) -------------------------------------------

# Max contact form submissions allowed per IP per window.
# 3 is the production default — generous enough for a real visitor who hits
# Send twice by accident, tight enough to stop spam.
RATE_LIMIT_MAX=3

# Window length in milliseconds. 600000 = 10 minutes.
# Combined with RATE_LIMIT_MAX, this means 3 submissions per 10 minutes per IP.
RATE_LIMIT_WINDOW_MS=600000


# ----- Compliance flags ------------------------------------------------------

# Whether to show the cookie consent banner on first visit.
# Must be `true` for any UK / EU / California-targeted site (GDPR, CCPA).
# Hjem is a UK business — leave true.
COOKIE_CONSENT_REQUIRED=true
