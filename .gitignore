# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ----- dependencies -----
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ----- testing & coverage -----
/coverage
.jest-cache/

# ----- next.js build output -----
/.next/
/out/

# ----- production builds -----
/build

# ----- env files (never commit secrets) -----
# .env.example IS committed as a template — every other .env* is local-only.
.env*
!.env.example

# ----- IDE & editor junk -----
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo

# ----- OS junk -----
.DS_Store
Thumbs.db
desktop.ini

# ----- debug logs -----
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ----- vercel deployment metadata -----
.vercel

# ----- typescript build artifacts -----
*.tsbuildinfo
next-env.d.ts

# ----- sentry config (generated on first sentry init, may contain auth token) -----
sentry.properties

# ----- docker overrides (per-developer customisation, not committed) -----
docker-compose.override.yml
